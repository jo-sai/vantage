# ==========================================================
# Vantage Backend — Environment Configuration
# ==========================================================
# Copy this file to ".env" and fill in your actual values.
# Without DATABASE_URL, the app runs in offline SQLite mode.
# ==========================================================

# --- Database ---
# Leave blank for offline SQLite mode (zero setup, no MariaDB needed).
# For MariaDB: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://vantage_user:your_strong_password_here@localhost:3306/vantage

# --- JWT Security ---
# Change these to long random strings before sharing with anyone!
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRY_MINUTES=10080
JWT_REFRESH_EXPIRY_DAYS=7

# --- Server ---
PORT=4000
NODE_ENV=development
# List allowed origins for CORS (comma-separated). Example:
# CORS_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

